# Docker Compose reads this file automatically when you run `docker compose`.
# Copy it to `.env` and fill the values for your deployment.
#
# Default Sprinto profile in this template:
# - Sprinto app + PostgreSQL run together in one Docker deployment
# - demo data is enabled
# - break-glass / recovery admin is enabled
# - you must fill the break-glass password before the first startup

# ---------------------------------------------------------------------------
# Database connection
# ---------------------------------------------------------------------------
# Default: bundled PostgreSQL service from docker-compose.yml.
DATABASE_URL=postgres://sprinto:sprinto@postgres:5432/sprinto

# If you want to use external PostgreSQL instead:
# - prepare a dedicated Sprinto database on the shared PostgreSQL server
# - do not mix Sprinto tables into another application's database
# DATABASE_URL=postgres://sprinto_user:replace-with-secret@db.company.local:5432/sprinto

# ---------------------------------------------------------------------------
# Database TLS for enterprise external PostgreSQL
# ---------------------------------------------------------------------------
# Default Sprinto profile keeps database TLS disabled because it talks to the
# bundled local PostgreSQL service.
SPRINTO_DB_SSL_ENABLED=false

# If you want external PostgreSQL TLS instead:
# SPRINTO_DB_SSL_ENABLED=true
# SPRINTO_DB_SSL_REJECT_UNAUTHORIZED=true
# SPRINTO_DB_SSL_CA_FILE=/run/sprinto-db-certs/ca.crt
# SPRINTO_DB_SSL_CERT_FILE=
# SPRINTO_DB_SSL_KEY_FILE=

# If the external PostgreSQL server requires mutual TLS:
# SPRINTO_DB_SSL_CERT_FILE=/run/sprinto-db-certs/client.crt
# SPRINTO_DB_SSL_KEY_FILE=/run/sprinto-db-certs/client.key

# ---------------------------------------------------------------------------
# Initial content bootstrap
# ---------------------------------------------------------------------------
# Default Sprinto profile keeps demo data enabled.
SPRINTO_SEED_DEMO_DATA=true

# ---------------------------------------------------------------------------
# Break-glass / recovery admin
# ---------------------------------------------------------------------------
# Default Sprinto profile keeps the break-glass account enabled as well.
# Fill the password before the first startup.
SPRINTO_RECOVERY_ADMIN_ENABLED=true
SPRINTO_RECOVERY_ADMIN_USERNAME=sprinto-recovery
SPRINTO_RECOVERY_ADMIN_PASSWORD=
SPRINTO_RECOVERY_ADMIN_DISPLAY_NAME=System Recovery Admin

# If you want a stricter production profile instead:
# - set SPRINTO_SEED_DEMO_DATA=false
# - keep SPRINTO_RECOVERY_ADMIN_ENABLED=true
# - keep DATABASE_URL on bundled PostgreSQL or replace it with an external
#   dedicated Sprinto database

# ---------------------------------------------------------------------------
# Update checks
# ---------------------------------------------------------------------------
UPDATE_REPOSITORY=AlienPixl/Sprinto
